{
  "name": "tributejs",
  "version": "3.6.0",
  "packageManager": "yarn@4.13.0",
  "description": "Native ES6 @mentions",
  "main": "dist/tribute.js",
  "types": "tributejs.d.ts",
  "devDependencies": {
    "babel-cli": "~6.26.0",
    "babel-plugin-add-module-exports": "^1.0.4",
    "babel-preset-env": "^1.6.1",
    "babelify": "^8.0.0",
    "browserify": "^17.0.0",
    "gulp": "^4.0.2",
    "gulp-babel": "^8.0.0",
    "gulp-plumber": "^1.1.0",
    "gulp-sass": "^5.1.0",
    "gulp-uglifyjs": "^0.6.2",
    "gulp-webserver": "^0.9.1",
    "jasmine-core": "^4.5.0",
    "karma": "^6.4.1",
    "karma-browserify": "^8.1.0",
    "karma-chrome-launcher": "^3.1.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.0.0",
    "karma-spec-reporter": "0.0.36",
    "node-sass": "^8.0.0",
    "npm-check-updates": "^20.0.0",
    "opn": "^6.0.0",
    "vinyl-source-stream": "^2.0.0",
    "watchify": "^4.0.0",
    "zombie": "^6.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/zurb/tribute.git"
  },
  "scripts": {
    "update": "yarn up -R '*' && yarn dedupe --strategy highest",
    "latest": "yarn npm-check-updates -i -m --packageManager yarn --install never && yarn install",
    "run": "babel src -w -d dist",
    "test": "karma start test/karma.conf.js"
  },
  "author": "Jordan Humphreys <jordan@zurb.com>",
  "license": "MIT"
}
